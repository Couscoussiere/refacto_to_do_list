{
  "name": "101-app",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "license": "MIT",
  "workspaces": [
    "auth-service",
    "project-service",
    "task-service",
    "notification-service"
  ],
  "scripts": {
    "prettify": "prettier -l --write \"**/*.js\"",
    "build": "tsc",
    "test:e2e": "playwright test",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:architecture": "depcruise . --config .dependency-cruiser.cjs",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "express": "^5.2.1",
    "mysql2": "^3.17.5",
    "sharp": "^0.35.2",
    "wait-port": "^1.1.0"
  },
  "resolutions": {
    "ansi-regex": "5.0.1"
  },
  "prettier": {
    "trailingComma": "all",
    "tabWidth": 4,
    "useTabs": false,
    "semi": true,
    "singleQuote": true
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "better-sqlite3": "^12.8.0",
    "dependency-cruiser": "^17.3.8",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.1",
    "node-addon-api": "^8.8.0",
    "nodemon": "^3.1.14",
    "nopt": "^9.0.0",
    "prebuild-install": "^7.1.3",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.1.0"
  }
}
