# Environment
NODE_ENV=test

# Frontend / Playwright
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000

# Legacy API port used by old Jest/Playwright tests
PORT=3000

# Microservices ports
AUTH_SERVICE_PORT=3001
PROJECT_SERVICE_PORT=3002
TASK_SERVICE_PORT=3003
NOTIFICATION_SERVICE_PORT=3004

# Microservices URLs
AUTH_SERVICE_URL=http://localhost:3001
PROJECT_SERVICE_URL=http://localhost:3002
TASK_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3004

# WebSocket
WS_PORT=3004
WS_URL=ws://localhost:3004

# Security
JWT_SECRET=test-jwt-secret

# Test databases
AUTH_SQLITE_DB_LOCATION=./.tmp/auth.test.db
PROJECT_SQLITE_DB_LOCATION=./.tmp/project.test.db
TASK_SQLITE_DB_LOCATION=./.tmp/task.test.db

# Messaging
RABBITMQ_URL=amqp://guest:guest@localhost:5672